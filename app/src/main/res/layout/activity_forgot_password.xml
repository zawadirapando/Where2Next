<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:context=".ForgotPasswordActivity">

    <TextView
        android:id="@+id/textBackToLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="32dp"
        android:text="Back"
        android:clickable="true"
        android:focusable="true"
        android:elevation="4dp"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="?attr/colorOnSurface"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textResetTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="90dp"
        android:text="Reset Password"
        android:textColor="?attr/colorOnSurface"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/textEmail"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textResetDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Enter your email address to receive a secure password reset link."
        android:textColor="#888888"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="@+id/textResetTitle"
        app:layout_constraintEnd_toEndOf="@+id/editResetEmail"
        app:layout_constraintTop_toBottomOf="@id/textResetTitle" />

    <TextView
        android:id="@+id/textEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="Email"
        android:textColor="?attr/colorOnSurface"
        app:layout_constraintStart_toStartOf="@+id/editResetEmail"
        app:layout_constraintTop_toBottomOf="@id/textResetDescription" />

    <EditText
        android:id="@+id/editResetEmail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/edittext_background"
        android:inputType="textEmailAddress"
        android:padding="14dp"
        android:textSize="15sp"
        android:textColor="?attr/colorOnSurface"
        android:textCursorDrawable="@null"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textEmail"
        app:layout_constraintWidth_percent="0.86" />

    <Button
        android:id="@+id/btnSendResetLink"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:background="@drawable/button_background"
        android:text="Send Reset Link"
        android:textColor="?attr/colorOnPrimary"
        app:layout_constraintStart_toStartOf="@+id/editResetEmail"
        app:layout_constraintTop_toBottomOf="@+id/editResetEmail"
        app:layout_constraintWidth_percent="0.86"/>

</androidx.constraintlayout.widget.ConstraintLayout>